@using BlazorSMTPForwarder.ServiceDefaults.Models

<div class="p-3">
    <div class="mb-3">
        <DxButton Variant="primary" Text="Add Domain" OnClick="@((MouseEventArgs e) => AddDomain())" />
    </div>

    @foreach (var domain in Domains)
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="m-0">@domain.DomainName</h5>
                <div class="d-flex gap-2">
                    <DxButton Variant="primary" Text="Check DNS" OnClick="@(async (MouseEventArgs e) => await CheckDnsClicked.InvokeAsync(domain))" />
                    <DxButton Variant="danger" Text="Remove" OnClick="@((MouseEventArgs e) => RemoveDomain(domain))" />
                </div>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label">Domain Name</label>
                        <DxTextBox @bind-Value="domain.DomainName" />
                    </div>

                    <div class="col-12">
                        <h6>Catch-All Action</h6>
                        <div class="d-flex gap-2 mb-2 align-items-center">
                            <DxSelect TValue="CatchAllType" @bind-Value="domain.CatchAll.Type"
                                      Items="_catchAllOptions" />
                            @if (domain.CatchAll.Type == CatchAllType.Forward)
                            {
                                <DxTextBox @bind-Value="domain.CatchAll.ForwardToEmail" Placeholder="Forward to..." />
                            }
                        </div>
                    </div>

                    <div class="col-12">
                        <h6>Forwarding Rules</h6>
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Incoming Email</th>
                                    <th>Destination Email</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var rule in domain.ForwardingRules)
                                {
                                    <tr>
                                        <td><DxTextBox @bind-Value="rule.IncomingEmail" /></td>
                                        <td><DxTextBox @bind-Value="rule.DestinationEmail" /></td>
                                        <td><DxButton Variant="danger" Text="Remove" OnClick="@((MouseEventArgs e) => domain.ForwardingRules.Remove(rule))" /></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        <DxButton Variant="primary" Text="Add Rule" OnClick="@((MouseEventArgs e) => domain.ForwardingRules.Add(new EmailForwardingRule()))" />
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="mt-3">
        <DxButton Variant="primary" Text="Save Settings" OnClick="@(async (MouseEventArgs e) => await SaveClicked.InvokeAsync())" />
    </div>
</div>

@code {
    [Parameter] public List<DomainConfiguration> Domains { get; set; } = new();
    [Parameter] public EventCallback SaveClicked { get; set; }
    [Parameter] public EventCallback<DomainConfiguration> CheckDnsClicked { get; set; }

    private readonly IReadOnlyList<ListOption<CatchAllType>> _catchAllOptions = Enum.GetValues<CatchAllType>()
        .Select(v => new ListOption<CatchAllType>(v, v.ToString(), false)).ToList();

    private void AddDomain()
    {
        Domains.Add(new DomainConfiguration { DomainName = "new-domain.com" });
    }

    private void RemoveDomain(DomainConfiguration domain)
    {
        Domains.Remove(domain);
    }
}
