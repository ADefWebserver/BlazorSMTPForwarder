@page "/settings"
@using Azure.Data.Tables
@using System.Text.Json
@using System.Text.Json.Nodes
@using BlazorSMTPForwarder.ServiceDefaults.Models
@using BlazorSMTPForwarder.Web.Components.Dialogs
@using BlazorSMTPForwarder.Web.GridRows
@using DnsClient
@using System.IO
@inject TableServiceClient Tables
@inject ILogger<Settings> Log
@inject IConfiguration Config
@inject IWebHostEnvironment Env
@inject ToastService ToastService
@inject BlazorSMTPForwarder.Web.Services.LogService LogService

<div>
    <h1 class="h3 mb-0">Settings</h1>
    <br />
    <DxTabs Items="_tabs" @bind-SelectedIndex="_selectedTab" />
</div>

<!-- DNS Check result dialog -->
<DxDialog @bind-Open="_dnsDialogOpen">
    <h4>@_dnsDialogTitle</h4>
    <p>@_dnsDialogMessage</p>
    <div class="d-flex justify-content-end">
        <DxButton Variant="primary" Text="OK" OnClick="@((MouseEventArgs e) => { _dnsDialogOpen = false; })" />
    </div>
</DxDialog>

@code {
    const string TableName = "SMTPSettings";
    const string PK = "SmtpServer";
    const string RKSettings = "Current";

    string? ServerName; string? AppPassword; string? SpamhausKey;
    string? SendGridApiKey; string? SendGridFromEmail;
    List<DomainConfiguration> Domains = new();
    bool Saved; string? Error;

    bool IsLoading; bool Saving;

    bool EnableSpamFiltering; bool EnableSpfCheck; bool EnableDmarcCheck; bool EnableDkimCheck;
    bool DoNotSaveMessages;

    // DNS dialog state
    bool _dnsDialogOpen;
    string _dnsDialogTitle = "";
    string _dnsDialogMessage = "";

    // Spam Log Logic
    List<SpamLog>? SpamLogs;
    IReadOnlyList<SpamLogRow> _spamRows = Array.Empty<SpamLogRow>();
    bool IsLoadingSpam;
    string? _spamContinuationToken;
    bool _spamHasMore;
    readonly int _spamPageSize = 200;

    // Server Log Logic
    IReadOnlyList<ServerLogRow> _logRows = Array.Empty<ServerLogRow>();
    bool IsLoadingLogs;
    // Cursor-based paging: _logPageStarts[i] is the start cursor (exclusive RowKey) for page i.
    readonly List<string?> _logPageStarts = new() { null };
    int _logPageIndex;
    bool _logsHasNext;
    readonly int _logsPageSize = 100;

    int _selectedTab;
    private IReadOnlyList<TabItem> _tabs => new List<TabItem>
    {
        new("General", @<GeneralSettingsTab ServerName="@ServerName" ServerNameChanged="@(v => ServerName = v)"
                           DoNotSaveMessages="@DoNotSaveMessages" DoNotSaveMessagesChanged="@(v => DoNotSaveMessages = v)"
                           AppPassword="@AppPassword" AppPasswordChanged="@(v => AppPassword = v)"
                           IsLoading="@IsLoading" Saved="@Saved" Error="@Error"
                           SaveClicked="@SaveAsync" ResetClicked="@RequestServerRestart" />),
        new("Domains", @<DomainsTab Domains="@Domains" SaveClicked="@SaveAsync" CheckDnsClicked="@CheckDomainDns" />),
        new("Spam", @<SpamTab SpamhausKey="@SpamhausKey" SpamhausKeyChanged="@(v => SpamhausKey = v)"
                 EnableSpamFiltering="@EnableSpamFiltering" EnableSpamFilteringChanged="@(v => EnableSpamFiltering = v)"
                 EnableSpfCheck="@EnableSpfCheck" EnableSpfCheckChanged="@(v => EnableSpfCheck = v)"
                 EnableDkimCheck="@EnableDkimCheck" EnableDkimCheckChanged="@(v => EnableDkimCheck = v)"
                 EnableDmarcCheck="@EnableDmarcCheck" EnableDmarcCheckChanged="@(v => EnableDmarcCheck = v)"
                 Rows="@_spamRows" IsLoading="@IsLoadingSpam" HasMore="@_spamHasMore"
                 SaveClicked="@SaveAsync" RefreshClicked="@LoadSpamLogsAsync" LoadMoreClicked="@LoadMoreSpamLogsAsync" />),
        new("SendGrid", @<SendGridTab SendGridApiKey="@SendGridApiKey" SendGridApiKeyChanged="@(v => SendGridApiKey = v)"
                     SendGridFromEmail="@SendGridFromEmail" SendGridFromEmailChanged="@(v => SendGridFromEmail = v)"
                     SaveClicked="@SaveAsync" />),
        new("Logs", @<LogsTab Rows="@_logRows" IsLoading="@IsLoadingLogs"
                 PageNumber="@(_logPageIndex + 1)" HasPrevious="@(_logPageIndex > 0)" HasNext="@_logsHasNext"
                 RefreshClicked="@LoadServerLogsAsync" PreviousClicked="@PreviousServerLogsAsync" NextClicked="@NextServerLogsAsync" />)
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        _ = LoadSpamLogsAsync();
        _ = LoadServerLogsAsync();
    }

    async Task LoadServerLogsAsync()
    {
        // Reset to the first page.
        _logPageStarts.Clear();
        _logPageStarts.Add(null);
        _logPageIndex = 0;
        await LoadServerLogPageAsync(0);
    }

    async Task NextServerLogsAsync()
    {
        if (IsLoadingLogs || !_logsHasNext) return;
        await LoadServerLogPageAsync(_logPageIndex + 1);
    }

    async Task PreviousServerLogsAsync()
    {
        if (IsLoadingLogs || _logPageIndex == 0) return;
        await LoadServerLogPageAsync(_logPageIndex - 1);
    }

    async Task LoadServerLogPageAsync(int pageIndex)
    {
        if (IsLoadingLogs) return;
        IsLoadingLogs = true;
        try
        {
            var startCursor = _logPageStarts[pageIndex];
            var result = await LogService.GetLogsAsync(_logsPageSize, startCursor);

            // Replace the grid contents with just this page.
            _logRows = result.Logs.Select(l => l.ToRow()).ToList();
            _logPageIndex = pageIndex;

            // If there's a next page, remember its start cursor.
            if (!string.IsNullOrEmpty(result.ContinuationToken))
            {
                _logsHasNext = true;
                if (pageIndex + 1 >= _logPageStarts.Count)
                    _logPageStarts.Add(result.ContinuationToken);
                else
                    _logPageStarts[pageIndex + 1] = result.ContinuationToken;
            }
            else
            {
                _logsHasNext = false;
            }
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to load server logs");
            _logsHasNext = false;
        }
        finally
        {
            IsLoadingLogs = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    async Task LoadAsync()
    {
        IsLoading = true; Error = null; Saved = false;
        try
        {
            var table = Tables.GetTableClient(TableName);
            await table.CreateIfNotExistsAsync();
            var settings = await table.GetEntityIfExistsAsync<TableEntity>(PK, RKSettings);
            if (settings.HasValue)
            {
                ServerName = settings.Value?.GetString("ServerName");
                SpamhausKey = settings.Value?.GetString("SpamhausKey");
                SendGridApiKey = settings.Value?.GetString("SendGridApiKey");
                SendGridFromEmail = settings.Value?.GetString("SendGridFromEmail");

                var domainsJson = settings.Value?.GetString("DomainsJson");
                if (!string.IsNullOrEmpty(domainsJson))
                {
                    try { Domains = JsonSerializer.Deserialize<List<DomainConfiguration>>(domainsJson) ?? new(); }
                    catch { Domains = new(); }
                }

                EnableSpamFiltering = settings.Value?.GetBoolean("EnableSpamFiltering") ?? false;
                EnableSpfCheck = settings.Value?.GetBoolean("EnableSpfCheck") ?? false;
                EnableDmarcCheck = settings.Value?.GetBoolean("EnableDmarcCheck") ?? false;
                EnableDkimCheck = settings.Value?.GetBoolean("EnableDkimCheck") ?? false;
                DoNotSaveMessages = settings.Value?.GetBoolean("DoNotSaveMessages") ?? false;
            }
            AppPassword = Config["AppPassword"];
        }
        catch (Exception ex) { Error = ex.Message; Log.LogError(ex, "Load failed"); }
        finally { IsLoading = false; }
    }

    async Task SaveAsync()
    {
        Error = null; Saved = false; Saving = true;
        try
        {
            await SaveAppPasswordToAppSettingsAsync(AppPassword ?? string.Empty);

            var table = Tables.GetTableClient(TableName);
            await table.CreateIfNotExistsAsync();

            var entity = new TableEntity(PK, RKSettings)
            {
                { "ServerName", ServerName },
                { "SendGridApiKey", SendGridApiKey },
                { "SendGridFromEmail", SendGridFromEmail },
                { "DomainsJson", JsonSerializer.Serialize(Domains) },
                { "EnableSpamFiltering", EnableSpamFiltering },
                { "EnableSpfCheck", EnableSpfCheck },
                { "EnableDmarcCheck", EnableDmarcCheck },
                { "EnableDkimCheck", EnableDkimCheck },
                { "DoNotSaveMessages", DoNotSaveMessages },
                { "SpamhausKey", SpamhausKey }
            };
            await table.UpsertEntityAsync(entity, TableUpdateMode.Merge);

            Saved = true;
        }
        catch (Exception ex) { Error = ex.Message; Log.LogError(ex, "Save failed"); }
        finally { Saving = false; }
    }

    async Task SaveAppPasswordToAppSettingsAsync(string value)
    {
        var path = Path.Combine(Env.ContentRootPath, "appsettings.json");
        string json;
        if (File.Exists(path))
        {
            json = await File.ReadAllTextAsync(path);
        }
        else
        {
            json = "{ }";
        }

        var newValueJson = JsonSerializer.Serialize(value);
        var regex = new System.Text.RegularExpressions.Regex(@"(""AppPassword""\s*:\s*)(""(?:[^""\\]|\\.)*""|null)", System.Text.RegularExpressions.RegexOptions.Singleline);

        if (regex.IsMatch(json))
        {
            json = regex.Replace(json, $"$1{newValueJson}");
        }
        else
        {
            var openBraceIndex = json.IndexOf('{');
            if (openBraceIndex >= 0)
            {
                json = json.Insert(openBraceIndex + 1, $"{Environment.NewLine}  \"AppPassword\": {newValueJson},");
            }
            else
            {
                var root = new JsonObject();
                root["AppPassword"] = value;
                json = root.ToJsonString(new JsonSerializerOptions { WriteIndented = true });
            }
        }

        await File.WriteAllTextAsync(path, json);
    }

    async Task RequestServerRestart()
    {
        try
        {
            var table = Tables.GetTableClient(TableName);
            await table.CreateIfNotExistsAsync();
            var entity = new TableEntity(PK, RKSettings)
            {
                { "RestartRequested", DateTime.UtcNow }
            };
            await table.UpsertEntityAsync(entity, TableUpdateMode.Merge);
            ToastService.Show("Restart signal sent to SMTP Service.", "success");
        }
        catch (Exception ex)
        {
            ToastService.Show($"Failed to send restart signal: {ex.Message}", "error");
        }
    }

    async Task CheckDomainDns(DomainConfiguration domain)
    {
        if (string.IsNullOrWhiteSpace(domain.DomainName)) return;

        try
        {
            var lookup = new LookupClient();
            var result = await lookup.QueryAsync(domain.DomainName, QueryType.MX);
            var record = result.Answers.MxRecords().OrderBy(x => x.Preference).FirstOrDefault();

            if (record != null && string.Equals(record.Exchange, (ServerName + "."), StringComparison.OrdinalIgnoreCase))
            {
                _dnsDialogTitle = "DNS Check";
                _dnsDialogMessage = $"MX record for {domain.DomainName} is correct ({record.Exchange}).";
            }
            else
            {
                var expected = string.IsNullOrWhiteSpace(ServerName) ? "[Local Domain not set]" : (ServerName + ".");
                _dnsDialogTitle = "DNS Check";
                _dnsDialogMessage = $"MX record for {domain.DomainName} is incorrect. Found: {record?.Exchange ?? "None"}. Expected: {expected}";
            }
            _dnsDialogOpen = true;
        }
        catch (Exception ex)
        {
            _dnsDialogTitle = "Error";
            _dnsDialogMessage = $"DNS check failed: {ex.Message}";
            _dnsDialogOpen = true;
        }
    }

    async Task LoadSpamLogsAsync()
    {
        _spamContinuationToken = null;
        _spamHasMore = true;
        SpamLogs = new List<SpamLog>();
        await LoadMoreSpamLogsAsync();
    }

    async Task LoadMoreSpamLogsAsync()
    {
        if (IsLoadingSpam || !_spamHasMore) return;
        IsLoadingSpam = true;
        try
        {
            var table = Tables.GetTableClient("spamlogs");
            await table.CreateIfNotExistsAsync();

            await foreach (var page in table.QueryAsync<TableEntity>().AsPages(_spamContinuationToken, _spamPageSize))
            {
                foreach (var entity in page.Values)
                {
                    var log = new SpamLog
                    {
                        PartitionKey = entity.PartitionKey,
                        RowKey = entity.RowKey,
                        Timestamp = ExtractSpamTimestamp(entity),
                        SessionId = entity.TryGetValue("SessionId", out var session) ? session?.ToString() : null,
                        TransactionId = entity.TryGetValue("TransactionId", out var txn) ? txn?.ToString() : null,
                        From = entity.TryGetValue("From", out var from) ? from?.ToString() : null,
                        To = entity.TryGetValue("To", out var to) ? to?.ToString() : null,
                        Subject = entity.TryGetValue("Subject", out var subj) ? subj?.ToString() : null,
                        BlobPath = entity.TryGetValue("BlobPath", out var blob) ? blob?.ToString() : null,
                        IP = entity.TryGetValue("IP", out var ip) ? ip?.ToString() : null
                    };
                    SpamLogs!.Add(log);
                }
                _spamContinuationToken = page.ContinuationToken;
                _spamHasMore = !string.IsNullOrEmpty(_spamContinuationToken);
                break;
            }

            SpamLogs = SpamLogs?.OrderByDescending(x => x.Timestamp).ToList();
            _spamRows = (SpamLogs ?? new()).Select(s => s.ToRow()).ToList();
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to load spam logs page");
            _spamHasMore = false;
        }
        finally
        {
            IsLoadingSpam = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    static DateTimeOffset? ExtractSpamTimestamp(TableEntity entity)
    {
        try
        {
            if (entity.TryGetValue("Timestamp", out var tsObj) && tsObj is not null)
            {
                if (tsObj is DateTime dt) return new DateTimeOffset(dt.ToUniversalTime());
                if (tsObj is DateTimeOffset dto) return dto.ToUniversalTime();
                if (DateTime.TryParse(tsObj.ToString(), out var parsed)) return new DateTimeOffset(parsed.ToUniversalTime());
            }
        }
        catch { }
        return entity.Timestamp;
    }
}
