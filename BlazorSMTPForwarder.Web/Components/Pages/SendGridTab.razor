<div class="p-3">
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label">API Key</label>
                    <DxPassword @bind-Value="SendGridApiKey" />
                </div>
                <div class="col-12">
                    <label class="form-label">From Email</label>
                    <DxTextBox @bind-Value="SendGridFromEmail" Placeholder="e.g. noreply@yourdomain.com" />
                    <div class="form-text">Must match a verified Sender Identity in SendGrid.</div>
                </div>
                <div class="col-12">
                    <DxButton Variant="primary" Text="Save Settings" OnClick="@(async (MouseEventArgs e) => await SaveClicked.InvokeAsync())" />
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string? SendGridApiKey { get; set; }
    [Parameter] public EventCallback<string?> SendGridApiKeyChanged { get; set; }
    [Parameter] public string? SendGridFromEmail { get; set; }
    [Parameter] public EventCallback<string?> SendGridFromEmailChanged { get; set; }
    [Parameter] public EventCallback SaveClicked { get; set; }
}
